datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. Define the User Table
model User {
  id        Int      @id @default(autoincrement()) // Unique ID that grows automatically
  email     String   @unique                      // Emails must be unique
  name      String?                               // The "?" means this field is optional
  password  String                                // We will hash this later for security!
  createdAt DateTime @default(now())              // Automatically sets the timestamp
  
  // Relationship: One user can have many posts
  posts     Post[]
}

// 2. Define the Post Table
model Post {
  id        Int      @id @default(autoincrement())
  title     String
  content   String?
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt                   // Automatically changes when updated

  // Relationship: Every post belongs to an Author (User)
  authorId  Int
  author    User     @relation(fields: [authorId], references: [id])
}